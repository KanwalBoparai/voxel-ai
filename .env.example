# ============================================================================
#  Voxel AI — infrastructure & secrets
#  Copy to .env and fill in. Only ANTHROPIC_API_KEY is needed for the live
#  browser demo (/demo). Twilio or Vapi is needed to place a real phone call.
#
#  NOTE: business details (name, industry, services, hours, FAQs, tone,
#  promotions) do NOT live here — they live in config/business.json. Swap that
#  file (or edit it from the dashboard) to run a different business.
# ============================================================================

# --- Claude: the agent brain (REQUIRED) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Most capable. For snappier phone latency: claude-haiku-4-5 or claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- Business config file (optional) ---
# Point at a different JSON to switch businesses, e.g. config/examples/law_firm.json
# BUSINESS_CONFIG_PATH=config/business.json

# --- Database ---
# Default is a local SQLite file (no setup). For Postgres, uncomment:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/voxel_ai

# --- Twilio: places the real call + does speech-to-text (needed for calls) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Text to speech ---
# "elevenlabs" = lifelike voice (fill the keys); "twilio" = built-in neural voice
# (instant, no extra account). Falls back to Twilio automatically if ElevenLabs fails.
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VOICE=Polly.Joanna-Neural

# --- Public URL Twilio/Vapi call back into (your ngrok URL or domain) ---
APP_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# --- Blanket outbound calling-hours guard (24hr). Per-day open/close comes
#     from config/business.json; this is an extra hard boundary. ---
CALL_START_HOUR=9
CALL_END_HOUR=19

# --- Vapi (cloud-hosted phone calls, no ngrok needed) ---
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# =============================================================================
#  CRM + Calendar (Google integration)
#  Setup steps:
#  1. Create a Google Cloud project and enable Calendar API + Sheets API.
#  2. Create a Service Account and download its JSON key.
#  3. Share your Google Calendar with the service account email (make changes).
#  4. Share your Google Sheet with the service account email (Editor).
#  5. Fill in the values below.
#
#  For local dev: set GOOGLE_SERVICE_ACCOUNT_FILE to the path of the JSON key.
#  For cloud/CI:  paste the full JSON content into GOOGLE_SERVICE_ACCOUNT_JSON.
#  Only one of the two is needed.
#
#  Appointment timezone comes from config/business.json (timezone field).
# =============================================================================

# Path to the service account JSON key file (local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# OR: paste the entire JSON as a single-line string (cloud / CI / Render)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Calendar ID — find it in Calendar Settings → "Integrate calendar"
# e.g. abc123xyz@group.calendar.google.com  (or "primary" for the main calendar)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Google Sheets ID — the long ID in the spreadsheet URL
# https://docs.google.com/spreadsheets/d/<THIS-PART>/edit
GOOGLE_SHEET_ID=your-spreadsheet-id
